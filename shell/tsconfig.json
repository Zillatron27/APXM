{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@apxm/bridge": ["../types/bridge.ts"]
    }
  },
  "include": ["src/**/*.ts", "../types/bridge.ts"]
}
